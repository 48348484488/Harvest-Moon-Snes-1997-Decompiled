+        %Set16bit(!MX)
+        PHX
+        PHX
+        TXA
+        JSL.L GetsCowPointer
+        %Set8bit(!M)
+        %Set16bit(!X)
+        PLX
+        LDY.W #$0000
+        LDA.B [$72],Y                        ;Status
+        AND.B #$01                           ;Exists
+        BNE .cowexists
+        JMP.W .skipcow
+
+    .cowexists:
+        %Set8bit(!M)
+        LDY.W #$0000
+        LDA.B [$72],Y                        ;Status
