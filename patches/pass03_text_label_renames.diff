+;;;;;;;; Does some weird things multypling some variables LOWBYTE and HIBYTE and suming the results with another variable????
+;;;;;;;; Param in A. Only called from Audio functions
+Unk_Audio23: ;838000
+        PHP
+        %Set16bit(!MX)
+        STA.W $011C
+        STZ.W $011E
+        STZ.W $0120
+        STZ.W $0122
+        %Set8bit(!M)
+        STA.W !multiplicand
+        LDA.B $7E
+        STA.W !multiplier
+        JSR.W MultiplicationUnsigned
+        %Set16bit(!M)
+        STA.W $011E
