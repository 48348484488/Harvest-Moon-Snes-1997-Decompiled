+CowFeedingandStatus: ;83BC5A
+        %Set16bit(!MX)
+        LDA.L $7F1F60
+        AND.W #$0001                         ;TODO
+        BEQ +
+        JMP.W .altcowfeed
+
+      + LDX.W #$0000
