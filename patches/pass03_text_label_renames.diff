+        LDA.W $0196
+        AND.W #$0002
+        BNE .cowunfed
+        LDA.W $0196
+        AND.W #$0008
+        BNE .CODE_83BD20
+        LDA.W $0196
+        AND.W #$0010
+        BNE .CODE_83BD30
+        LDA.W $0196
+        AND.W #$0200
